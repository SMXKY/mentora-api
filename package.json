{
  "name": "mentora-api",
  "version": "1.0.0",
  "description": "\"# mentora-api\"",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "npx prisma generate && tsc && cp -r src/generated dist/src/generated && cp -r src/public dist/src/public && cp -r src/locales dist/src/locales && cp -r docs dist/docs",
    "start": "node dist/index.js",
    "scaffold": "ts-node cli/scaffold.ts",
    "docs:build": "ts-node cli/build-docs.ts",
    "docs:watch": "nodemon --watch src --ext ts --exec npm run docs:build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration:media:dev": "cross-env NODE_ENV=development jest tests/media.service.integration.test.ts --runInBand --forceExit",
    "test:integration:media:prod": "cross-env NODE_ENV=production CLAMAV_ENABLED=false jest tests/media.service.integration.test.ts --runInBand --forceExit",
    "test:k6:notifications": "k6 run k6/notification-flow.test.js",
    "test:k6:media": "ts-node k6/support/seed-media-test-user.ts && k6 run k6/media-http-flow.test.js",
    "test:integration": "npm run test:integration:media:dev && npm run test:integration:media:prod && npm run test:k6:notifications && npm run test:k6:media",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SMXKY/mentora-api.git"
  },
  "keywords": [],
  "author": "smxky",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SMXKY/mentora-api/issues"
  },
  "homepage": "https://github.com/SMXKY/mentora-api#readme",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@clerk/express": "^2.1.26",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "africastalking": "^0.7.9",
    "argon2": "^0.44.0",
    "axios": "^1.16.1",
    "bullmq": "^5.79.2",
    "clamav.js": "^0.12.0",
    "clamscan": "^2.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.5.2",
    "file-type": "^16.5.4",
    "firebase-admin": "^13.10.0",
    "fluent-ffmpeg": "^2.1.3",
    "ftp": "^0.3.10",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "http-status-codes": "^2.3.0",
    "i18next": "^26.3.1",
    "i18next-fs-backend": "^2.6.6",
    "ioredis": "^5.11.0",
    "multer": "^2.1.1",
    "music-metadata": "^11.13.0",
    "nodemailer": "^8.0.10",
    "pdf-lib": "^1.17.1",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^6.0.0",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "svix": "^1.95.2",
    "swagger-ui-express": "^5.0.1",
    "ua-parser-js": "^2.0.10",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/internals": "^7.8.0",
    "@types/africastalking": "^0.8.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/ftp": "^0.3.36",
    "@types/handlebars": "^4.0.40",
    "@types/http-status-codes": "^1.2.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "handlebars": "^4.7.9",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
