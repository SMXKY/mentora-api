  STUDENT_SUBJECT
  TUTOR_SUBJECT
  PLATFORM_AGGREGATE
}

enum EngagementTrend {
  IMPROVING
  STABLE
  DECLINING
  INSUFFICIENT_DATA
}

model LearningAnalyticsSnapshot {
  id                 String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope              LearningSnapshotScope

  studentProfileId   String?               @map("student_profile_id") @db.Uuid
  tutorId            String?               @map("tutor_id") @db.Uuid
  subjectId          String?               @map("subject_id") @db.Uuid

  sessionsCompletedThisMonth Int?          @map("sessions_completed_this_month")
  sessionsCompletedAllTime   Int?          @map("sessions_completed_all_time")
  currentStreakWeeks         Int?          @map("current_streak_weeks")
  longestStreakWeeks         Int?          @map("longest_streak_weeks")
  streakActive               Boolean?     @map("streak_active")
  consistencyScorePercent    Int?          @map("consistency_score_percent")
  sessionFrequencyTrend      Int[]        @map("session_frequency_trend")
  totalMaterialsAvailable    Int?          @map("total_materials_available")
  totalMaterialsAccessed     Int?          @map("total_materials_accessed")
  materialsAccessRatio       Int?          @map("materials_access_ratio")
  lastMaterialAccessedAt     DateTime?    @map("last_material_accessed_at")
  lastMaterialTitle          String?       @map("last_material_title") @db.VarChar(255)
  topicsCoveredCount         Int?          @map("topics_covered_count")
  topicsTotalCount           Int?          @map("topics_total_count")
  engagementTrend            EngagementTrend? @map("engagement_trend")

  studentOverview             Json?         @map("student_overview")
  subjectRebookingRatePercent Int?          @map("subject_rebooking_rate_percent")
  avgSessionsBeforeChurn      Decimal?     @map("avg_sessions_before_churn") @db.Decimal(4, 1)
  materialsAccessRatePercent  Int?          @map("materials_access_rate_percent")
  studentRetentionRatePercent Int?          @map("student_retention_rate_percent")
  sessionsPerWeekTrend        Int[]        @map("sessions_per_week_trend")

  platformAvgSessionsBeforeChurn        Decimal? @map("platform_avg_sessions_before_churn") @db.Decimal(4, 1)
  materialUploadRebookingCorrelation    Decimal? @map("material_upload_rebooking_correlation") @db.Decimal(3, 2)
  consistencyRebookingCorrelation       Decimal? @map("consistency_rebooking_correlation") @db.Decimal(3, 2)
  avgTopicsBeforeChurn                  Decimal? @map("avg_topics_before_churn") @db.Decimal(4, 1)
  avgStreakWeeks                        Decimal? @map("avg_streak_weeks") @db.Decimal(4, 1)

  computedAt           DateTime @default(now()) @map("computed_at")
  computationDurationMs Int?    @map("computation_duration_ms")
  coversPeriodFrom     DateTime @map("covers_period_from")
  coversPeriodTo       DateTime @map("covers_period_to")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  studentProfile StudentProfile? @relation(fields: [studentProfileId], references: [id])
  tutor          User?           @relation(fields: [tutorId], references: [id])
  subject        Subject?        @relation(fields: [subjectId], references: [id])

  @@index([scope])
  @@index([studentProfileId])
  @@index([tutorId])
  @@index([subjectId])
  @@index([computedAt])
  @@index([engagementTrend])
  @@index([studentProfileId, subjectId, computedAt], map: "idx_learning_student_subject")
  @@index([tutorId, subjectId, computedAt], map: "idx_learning_tutor_subject")
  @@index([scope, computedAt], map: "idx_learning_scope_time")
  @@map("learning_analytics_snapshots")
}

enum ConfigCategory {
  RBAC
  RATE_LIMITING
  FEATURE_FLAGS
  MEDIA
  STORAGE
  SECURITY
  LOCALIZATION
}

model PlatformConfig {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key          String         @unique @db.VarChar(200)
  value        Json
  category     ConfigCategory
  description  String
  defaultValue Json           @map("default_value")
  isSensitive  Boolean        @default(false) @map("is_sensitive")
  updatedById  String         @map("updated_by") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  updatedBy User @relation(fields: [updatedById], references: [id])

  @@index([category])
  @@map("platform_configs")
}
