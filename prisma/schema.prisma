datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

model HealthCheck {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
}

model TestResource {
  id        String   @id @default(uuid())
  name      String   @unique
  status    String   @default("active")
  notes     String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name        String   @unique @db.VarChar(100)
  description String?

  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  rolePermissions      RolePermission[]
  userRoles            UserRole[]
  storageQuotaDefaults StorageQuotaDefault[]

  @@index([isActive])
  @@map("roles")
}

model PermissionModule {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  nameLocaleCode        String   @unique @map("name_locale_code") @db.VarChar(100)
  descriptionLocaleCode String?  @map("description_locale_code") @db.VarChar(100)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  submodules  PermissionSubmodule[]
  permissions Permission[]

  @@map("permission_modules")
}

model PermissionSubmodule {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nameLocaleCode        String   @unique @map("name_locale_code") @db.VarChar(100)
  descriptionLocaleCode String?  @map("description_locale_code") @db.VarChar(100)
  permissionModuleId    String   @map("permission_module_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  permissionModule PermissionModule @relation(fields: [permissionModuleId], references: [id])
  permissions      Permission[]

  @@index([permissionModuleId])
  @@map("permission_submodules")
}

model Permission {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  code                  String   @unique @db.VarChar(100)

  nameLocaleCode        String   @unique @map("name_locale_code") @db.VarChar(100)
  descriptionLocaleCode String?  @map("description_locale_code") @db.VarChar(100)

  isSystem              Boolean  @default(false) @map("is_system")
  permissionModuleId    String   @map("permission_module_id") @db.Uuid
  permissionSubmoduleId String?  @map("permission_submodule_id") @db.Uuid
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  permissionModule    PermissionModule     @relation(fields: [permissionModuleId], references: [id])
  permissionSubmodule PermissionSubmodule? @relation(fields: [permissionSubmoduleId], references: [id])
  rolePermissions     RolePermission[]
  overrides           PermissionOverride[]

  implies             PermissionImplication[] @relation("ImplicationSource")

  impliedBy           PermissionImplication[] @relation("ImplicationTarget")

  @@index([permissionModuleId])
  @@index([permissionSubmoduleId])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdById  String   @map("created_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  createdBy  User       @relation("RolePermissionCreatedBy", fields: [createdById], references: [id])

  @@unique([roleId, permissionId], map: "unique_role_permission")
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  roleId      String    @map("role_id") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")
  
  expiresAt   DateTime? @map("expires_at")
  createdById String    @map("created_by") @db.Uuid
  reason      String?   @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user      User @relation("UserRoleUser", fields: [userId], references: [id])
  role      Role @relation(fields: [roleId], references: [id])
  createdBy User @relation("UserRoleCreatedBy", fields: [createdById], references: [id])

  @@unique([userId, roleId], map: "unique_user_role")
  @@index([userId])
  @@index([roleId])
  @@index([userId, roleId, isActive], map: "idx_user_role_active_lookup")
  @@index([expiresAt])
  @@index([isActive])
  @@map("user_roles")
}

enum GrantType {
  GRANT
  REVOKE
}

model PermissionOverride {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  grantType    GrantType @map("grant_type")
 
  expiresAt    DateTime? @map("expires_at")
  createdById  String    @map("created_by") @db.Uuid
  reason       String?   @db.VarChar(255)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user       User       @relation("PermissionOverrideUser", fields: [userId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])
  createdBy  User       @relation("PermissionOverrideCreatedBy", fields: [createdById], references: [id])

  @@unique([userId, permissionId], map: "unique_user_permission_override")
  @@index([userId])
  @@index([permissionId])
  @@index([expiresAt])
  @@index([grantType])
  @@map("permission_overrides")
}

model PermissionImplication {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  permissionId        String   @map("permission_id") @db.Uuid
  impliedPermissionId String   @map("implied_permission_id") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")

  permission        Permission @relation("ImplicationSource", fields: [permissionId], references: [id])
  impliedPermission Permission @relation("ImplicationTarget", fields: [impliedPermissionId], references: [id])

  @@unique([permissionId, impliedPermissionId], map: "unique_permission_implication")
  @@index([permissionId])
  @@index([impliedPermissionId])
  @@map("permission_implications")
}

model IpBlock {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ipAddress   String    @map("ip_address") @db.VarChar(45)
  ipRange     String?   @map("ip_range") @db.VarChar(50)
  reason      String
  blockedById String    @map("blocked_by") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  blockedBy User @relation("IpBlockBlockedBy", fields: [blockedById], references: [id])

  @@index([ipAddress])
  @@index([isActive])
  @@index([expiresAt])
  @@index([ipAddress, isActive], map: "idx_ip_blocks_lookup")
  @@map("ip_blocks")
}

enum LogOperation {
  CREATE
  READ
  UPDATE
  DELETE
  RESTORE
  SUSPEND
  UNSUSPEND
  BAN
  APPROVE
  REJECT
  RELEASE
  REFUND
  TRANSFER
  AUTH
  FORGOT_PASSWORD
  RESET_PASSWORD
  CHANGE_PASSWORD
  CHANGE_USER_CREDENTIALS
}

enum LogCategory {
  WRITE
  READ
  SENSITIVE_READ
  AUTH
}

enum LogStatus {
  SUCCESS
  FAILED
}

model AuditLog {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId       String?      @map("actor_id") @db.Uuid
  actorEmail    String?      @map("actor_email") @db.VarChar(255)
  actorRole     String?      @map("actor_role") @db.VarChar(50)
  eventType     String       @map("event_type") @db.VarChar(100)
  operation     LogOperation
  category      LogCategory
  status        LogStatus    @default(SUCCESS)
  failureReason String?      @map("failure_reason")
  tableName     String       @map("table_name") @db.VarChar(100)
  targetId      String?      @map("target_id") @db.VarChar(255)
  targetType    String?      @map("target_type") @db.VarChar(100)
  previousState Json?        @map("previous_state")
  newState      Json?        @map("new_state")
  changedFields String[]     @map("changed_fields")
  ipAddress     String?      @map("ip_address") @db.VarChar(45)
  userAgent     String?      @map("user_agent")
  requestId     String?      @map("request_id") @db.Uuid
  metadata      Json?
  createdAt     DateTime     @default(now()) @map("created_at")

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([eventType])
  @@index([operation])
  @@index([tableName])
  @@index([targetId])
  @@index([targetType])
  @@index([createdAt])
  @@index([status])
  @@index([actorId, createdAt], map: "idx_audit_actor_time")
  @@index([targetId, eventType], map: "idx_audit_target_event")
  @@index([tableName, operation], map: "idx_audit_table_operation")
  @@map("audit_logs")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DEACTIVATED
  BANNED
}

enum UserGender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum PaymentAccountType {
  MTN_MOMO
  ORANGE_MONEY
}

enum SuspensionType {
  SUSPENSION
  BAN
}

enum PlatformTokenType {
  WHATSAPP_VERIFICATION
  INVITE_LINK
}

enum Languages{
  EN
  FR
}

model User {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
 
  clerkId        String  @unique @map("clerk_id") @db.VarChar(255)
  googleAuthId   String? @unique @map("google_auth_id") @db.VarChar(255)
  facebookAuthId String? @unique @map("facebook_auth_id") @db.VarChar(255)

  firstName       String? @map("first_name") @db.VarChar(100)
  lastName        String? @map("last_name") @db.VarChar(155)
  username        String? @unique @db.VarChar(100)
  email           String  @unique @db.VarChar(255)
  isEmailVerified Boolean @default(false) @map("is_email_verified")


  phoneNumber     String?   @map("phone_number") @db.VarChar(20)
  
  whatsappNumber  String?   @map("whatsapp_number") @db.VarChar(20)
  whatsappOptIn   Boolean   @default(false) @map("whatsapp_opt_in")
  whatsappOptInAt DateTime? @map("whatsapp_opt_in_at")

  dob               DateTime?  @db.Date
  gender            UserGender @default(PREFER_NOT_TO_SAY)
  profilePictureUrl String?    @map("profile_picture_url") @db.VarChar(500)
  address           String?    @db.VarChar(500)
  
  preferredLanguage Languages     @default(EN) @map("preferred_language")

  notificationsMuted Boolean @default(false) @map("notifications_muted")

  status            UserStatus @default(ACTIVE)
  isSystem          Boolean    @default(false) @map("is_system")
  isAccountComplete Boolean    @default(false) @map("is_account_complete")

  lastLoggedInAt DateTime? @map("last_logged_in_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

 
  rolePermissionsCreated     RolePermission[]     @relation("RolePermissionCreatedBy")
  userRoles                  UserRole[]           @relation("UserRoleUser")
  userRolesCreated           UserRole[]           @relation("UserRoleCreatedBy")
  permissionOverrides        PermissionOverride[] @relation("PermissionOverrideUser")
  permissionOverridesCreated PermissionOverride[] @relation("PermissionOverrideCreatedBy")
 
  ipBlocksCreated IpBlock[]  @relation("IpBlockBlockedBy")
  auditLogs       AuditLog[] @relation("AuditLogActor")

  devices             UserDevice[]
  sessions            UserSession[]       @relation("UserSessionUser")
  sessionsTerminated  UserSession[]       @relation("UserSessionTerminatedBy")
  platformTokens      PlatformToken[]
  paymentAccounts     PaymentAccount[]
  suspensions         AccountSuspension[] @relation("AccountSuspensionUser")
  suspensionsLifted   AccountSuspension[] @relation("AccountSuspensionLiftedBy")
  suspensionsCreated  AccountSuspension[] @relation("AccountSuspensionCreatedBy")
  studentProfiles     StudentProfile[]

  tutorProfile               TutorProfile?
  relationshipWeightsSet     SubjectRelationshipWeight[]
  credentialsReviewed        TutorCredential[]
  tutorSubjectsApproved      TutorSubject[]
  
  filesUploaded         File[]
  quotaDefaultsCreated  StorageQuotaDefault[]
  quotaOverride         StorageQuotaOverride? @relation("QuotaOverrideUser")
  quotaOverridesGranted StorageQuotaOverride[] @relation("QuotaOverrideGrantedBy")
  storageUsage          StorageUsage?
  
  materialAccess          MaterialAccess[]
  materialReviewsActioned MaterialReview[] @relation("MaterialReviewReviewedBy")
  materialReviewsAgainst  MaterialReview[] @relation("MaterialReviewTutor")
  materialReviewsReported MaterialReview[] @relation("MaterialReviewReportedBy")
 
  kycStatusChanges        KycStatusHistory[]
  kycChecklistSubmissions KycChecklistSubmission[]
  kycBansIssued           KycBan[]
  
  demandSignals DemandSignal[]
  
  bookingSeries          BookingSeries[]
  bookings               Booking[]                 @relation("BookingBooker")
  bookingsCancelled      Booking[]                 @relation("BookingCancelledBy")
  groupParticipations    GroupSessionParticipant[]
  rescheduleRequests     RescheduleRequest[]       @relation("RescheduleRequestedBy")
  rescheduleResponses    RescheduleRequest[]       @relation("RescheduleRespondedBy")
 
  notifications          Notification[]
  scheduledNotifications ScheduledNotification[]
  notificationPrefs      NotificationPreference[]
  pushTokens             PushToken[]

  wallet                   Wallet?
  escrowHoldsPaid          EscrowHold[]            @relation("EscrowPayer")
  escrowHoldsReceiving     EscrowHold[]            @relation("EscrowTutor")
  ledgerEntriesFrom        TransactionLedger[]     @relation("LedgerFromUser")
  ledgerEntriesTo          TransactionLedger[]     @relation("LedgerToUser")
  ledgerAdjustments        TransactionLedger[]     @relation("LedgerPerformedBy")
  payoutQueueEntries       PayoutQueue[]
  idempotencyKeys          IdempotencyKey[]
  paymentReconciliations   PaymentReconciliation[]
  transactionIssues        TransactionIssue[]      @relation("TransactionIssueUser")
  transactionIssuesResolved TransactionIssue[]     @relation("TransactionIssueResolvedBy")
  receipts                 Receipt[]
 
  sessionParticipations    SessionParticipant[]
  participantEvents        ParticipantEvent[]       @relation("ParticipantEventUser")
  participantEventsActioned ParticipantEvent[]      @relation("ParticipantEventActionedBy")
  connectionQualityEvents  ConnectionQualityEvent[]

  conversationsFrozen        Conversation[]            @relation("ConversationFrozenBy")
  conversationParticipations ConversationParticipant[] @relation("ConvParticipantUser")
  conversationMembersAdded   ConversationParticipant[] @relation("ConvParticipantAddedBy")
  conversationMembersRemoved ConversationParticipant[] @relation("ConvParticipantRemovedBy")
  messagesSent               Message[]                 @relation("MessageSender")
  messagesDeleted            Message[]                 @relation("MessageDeletedBy")
  messageReadReceipts        MessageReadReceipt[]
  filterBlocks               FilterBlock[]
  moderationReportsFiled     ModerationReview[]        @relation("ModerationReportedBy")
  moderationReviewsDone      ModerationReview[]        @relation("ModerationReviewedBy")
  sessionChatMessages        SessionChatMessage[]      @relation("SessionChatSender")
  sessionChatMessagesDeleted SessionChatMessage[]      @relation("SessionChatDeletedBy")
  filterKeywordsAdded        FilterKeyword[]
  
  lessonConfirmations    LessonConfirmation[]
  disputesOpened         Dispute[]              @relation("DisputeOpenedBy")
  disputesAssigned       Dispute[]              @relation("DisputeAssignedTo")
  disputesResolved       Dispute[]              @relation("DisputeResolvedBy")
  disputeEvidenceUploads DisputeEvidenceFile[]
  incidentReportsFiled   IncidentReport[]       @relation("IncidentReportedBy")
  incidentReportsAgainst IncidentReport[]       @relation("IncidentReportedAgainst")
  incidentReportsReviewed IncidentReport[]      @relation("IncidentReviewedBy")

  reviewWindowsReopened ReviewWindow[]
  reviewsAuthored       Review[]             @relation("ReviewAuthor")
  reviewsReceived       Review[]             @relation("ReviewSubject")
  reviewsDeleted        Review[]             @relation("ReviewDeletedBy")
  ratingSnapshot        TutorRatingSnapshot?
  reviewReportsFiled    ReviewReport[]       @relation("ReviewReportReportedBy")
  reviewReportsReviewed ReviewReport[]       @relation("ReviewReportReviewedBy")
  reviewFraudSignals    ReviewFraudSignal[]
 
  riskScore             RiskScore?         @relation("RiskScoreUser")
  riskReviewsCompleted  RiskScore[]        @relation("RiskScoreReviewedBy")
  riskSignals           RiskSignal[]       @relation("RiskSignalUser")
  riskAdjustmentsMade   RiskSignal[]       @relation("RiskSignalPerformedBy")
  riskStateHistory      RiskStateHistory[] @relation("RiskStateUser")
  riskStatesCleared     RiskStateHistory[] @relation("RiskStateClearedBy")
  reauthChallenges      ReauthChallenge[]
  fingerprintEntries    DeviceFingerprintRegistry[]
 
  deadLetterJobs          DeadLetterJob[]       @relation("DlqUser")
  deadLetterJobsRetried   DeadLetterJob[]       @relation("DlqRetriedBy")
  deadLetterJobsDismissed DeadLetterJob[]       @relation("DlqDismissedBy")
  ticketsSubmitted        SupportTicket[]       @relation("TicketSubmittedBy")
  ticketsAssigned         SupportTicket[]       @relation("TicketAssignedTo")
  ticketsEscalatedTo      SupportTicket[]       @relation("TicketEscalatedTo")
  ticketsResolved         SupportTicket[]       @relation("TicketResolvedBy")
  ticketMessages          TicketMessage[]
  ticketAttachments       TicketAttachment[]
  ticketStatusChanges     TicketStatusHistory[]
  payoutRetriesInitiated  FailedPayoutContext[]
  reconciliationsResolved ReconciliationContext[]

  scheduledReportsCreated ScheduledReport[]
  generatedReports        GeneratedReport[]
  heartbeatJobsDisabled   JobHeartbeatRegistry[]
  learningSnapshots       LearningAnalyticsSnapshot[]
  platformConfigsUpdated  PlatformConfig[]
  monthlyFeeCharges       MonthlyFeeCharge[]

  @@index([status])
  @@index([isAccountComplete])
  @@index([email, status], map: "idx_users_email_status")
  @@index([firstName, lastName], map: "idx_users_name")
  @@map("users")
}

model UserDevice {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
 
  deviceFingerprintHash String    @map("device_fingerprint_hash") @db.VarChar(255)
  ipAddress             String?   @map("ip_address") @db.VarChar(45)
  os                    String?   @db.VarChar(100)
  browser               String?   @db.VarChar(100)
  browserVersion        String?   @map("browser_version") @db.VarChar(50)
 
  deviceType            String?   @map("device_type") @db.VarChar(50)
  lastSeenAt            DateTime? @map("last_seen_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user       User          @relation(fields: [userId], references: [id])
  sessions   UserSession[]
  pushTokens PushToken[]

  @@index([userId])
  @@index([deviceFingerprintHash])
  @@index([userId, deviceFingerprintHash], map: "idx_user_device_fingerprint")
  @@map("user_devices")
}

model UserSession {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  deviceId       String    @map("device_id") @db.Uuid
  isActive       Boolean   @default(true) @map("is_active")
  expiresAt      DateTime  @map("expires_at")
  lastActiveAt   DateTime? @map("last_active_at")
  terminatedAt   DateTime? @map("terminated_at")
  terminatedById String?   @map("terminated_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user         User       @relation("UserSessionUser", fields: [userId], references: [id])
  device       UserDevice @relation(fields: [deviceId], references: [id])
  terminatedBy User?      @relation("UserSessionTerminatedBy", fields: [terminatedById], references: [id])

  @@index([userId])
  @@index([deviceId])
  @@index([isActive])
  @@index([expiresAt])
  @@index([userId, isActive], map: "idx_sessions_user_active")
  @@map("user_sessions")
}

model PlatformToken {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  tokenHash     String            @unique @map("token_hash") @db.VarChar(255)
  tokenType     PlatformTokenType @map("token_type")
  expiresAt     DateTime          @map("expires_at")
  usedAt        DateTime?         @map("used_at")
  attemptCount  Int               @default(0) @map("attempt_count")
  invalidatedAt DateTime?         @map("invalidated_at")
  createdAt     DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenType])
  @@index([expiresAt])
  @@index([userId, tokenType], map: "idx_tokens_user_type")
  @@map("platform_tokens")
}

model PaymentAccount {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String             @map("user_id") @db.Uuid
  phoneNumber    String             @map("phone_number") @db.VarChar(20)
  accountType    PaymentAccountType @map("account_type")
  isVerified     Boolean            @default(false) @map("is_verified")
  isPrimary      Boolean            @default(false) @map("is_primary")
 
  coolingOffUntil DateTime?         @map("cooling_off_until")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  user         User          @relation(fields: [userId], references: [id])
  payoutQueues PayoutQueue[]

  @@unique([userId, phoneNumber, accountType], map: "idx_payment_account_unique")
  @@index([userId])
  @@index([accountType])
  @@index([isVerified])
  @@index([coolingOffUntil])
  @@map("payment_accounts")
}

model AccountSuspension {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  suspensionType SuspensionType @default(SUSPENSION) @map("suspension_type")
  reason         String
  expiresAt      DateTime?      @map("expires_at")
  liftedAt       DateTime?      @map("lifted_at")
  liftedById     String?        @map("lifted_by") @db.Uuid
  createdById    String         @map("created_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user      User  @relation("AccountSuspensionUser", fields: [userId], references: [id])
  liftedBy  User? @relation("AccountSuspensionLiftedBy", fields: [liftedById], references: [id])
  createdBy User  @relation("AccountSuspensionCreatedBy", fields: [createdById], references: [id])

  @@index([userId])
  @@index([suspensionType])
  @@index([liftedAt])
  @@index([expiresAt])
  @@index([userId, liftedAt], map: "idx_suspensions_active")
  @@map("account_suspensions")
}

enum KycStatus {
  INCOMPLETE
  PENDING
  IDENTITY_APPROVED
  ACTIVE
  REJECTED
  SUSPENDED
  BANNED
  PENDING_REVERIFICATION
}

enum QualificationType {
  BSC
  MSC
  PHD
  PGDE
  TEACHING_CERTIFICATE
  PROFESSIONAL_CERTIFICATION
  HND
  GCE_A_LEVEL
  GCE_O_LEVEL
  OTHER
}

enum CredentialStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubjectVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TeachingMode {
  ONLINE_ONLY
  HOME_ONLY
  BOTH
}

enum AvailabilitySlotType {
  RECURRING
  SPECIFIC_DATE
}

enum AvailabilityDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum SchoolType {
  PRIMARY
  SECONDARY
  GCE
  UNIVERSITY
  OTHER
}

enum PreferredSessionMode {
  ONLINE
  HOME
  BOTH
}

model Region {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(100)
  countryCode String   @default("CM") @map("country_code") @db.VarChar(5)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cities          City[]
  kycApplications KycApplication[]

  @@index([countryCode])
  @@index([isActive])
  @@map("regions")
}

model City {
