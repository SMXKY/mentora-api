model File {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uploadedById String @map("uploaded_by") @db.Uuid
  refTable    String? @map("ref_table") @db.VarChar(100)
  refRecordId String? @map("ref_record_id") @db.Uuid
  originalFileName String @map("original_file_name") @db.VarChar(255)

  storagePath      String @map("storage_path") @db.VarChar(500)
  fileCategory     FileCategory @map("file_category")
  fileType         FileType     @map("file_type")
  mimeType         String       @map("mime_type") @db.VarChar(100)
  fileSizeBytes    BigInt       @map("file_size_bytes")
  uploadType       FileUploadType @map("upload_type")
  status                FileProcessingStatus @default(PENDING)
  processingStartedAt   DateTime?            @map("processing_started_at")
  processingCompletedAt DateTime?            @map("processing_completed_at")
  processingError       String?              @map("processing_error")
  
  scanResult      String?   @map("scan_result") @db.VarChar(50)
  scanCompletedAt DateTime? @map("scan_completed_at")
  isDisputeLocked Boolean   @default(false) @map("is_dispute_locked")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  uploadedBy User          @relation(fields: [uploadedById], references: [id])
  variants   FileVariant[]
  materials  Material[]
  
  kycFrontPhotos  KycApplication[] @relation("KycCniFront")
  kycBackPhotos   KycApplication[] @relation("KycCniBack")
  kycSelfiePhotos KycApplication[] @relation("KycSelfie")

  whiteboardRooms LiveRoom[] @relation("RoomWhiteboardFile")
  recordingRooms  LiveRoom[] @relation("RoomRecordingFile")
  
  disputeEvidence   DisputeEvidenceFile[]
  ticketAttachments TicketAttachment[]
  generatedReports  GeneratedReport[]
  receipts          Receipt[]

  @@index([uploadedById])
  @@index([fileCategory])
  @@index([fileType])
  @@index([status])
  @@index([refTable])
  @@index([refRecordId])
  @@index([refTable, refRecordId], map: "idx_files_polymorphic")
  @@index([uploadedById, fileCategory], map: "idx_files_owner_category")
  @@index([deletedAt])
  @@index([isDisputeLocked])
  @@map("files")
}

enum FileVariantType {
  VIDEO_720P
  VIDEO_360P
  /// 800x800 max profile photo
  IMAGE_RESIZED
  IMAGE_THUMBNAIL
